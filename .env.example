# Frontend (Vite) — copy to .env.local, never commit real values
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: override Edge Functions base URL
# VITE_SUPABASE_FUNCTIONS_BASE_URL=https://YOUR_PROJECT.supabase.co/functions/v1/server

# Supabase Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# APP_URL=https://your-production-app.example
# ALLOWED_ORIGINS=https://your-production-app.example,http://localhost:5173
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_WEBHOOK_SECRET=
# USSD_GATEWAY_SECRET=
# ENABLE_LEGACY_PAYOUT_SWEEPER=false

# ===========================================================================
# Auxiliary Backend Systems (Phase 11: Production Hardening)
# ===========================================================================
# IMPORTANT: Copy these definitions to your local `.env` file before running
# `docker-compose up -d` in production or staging environment.

POSTGRES_USER=kithly_db_admin
POSTGRES_PASSWORD=kithly_secure_db_pass_2026
POSTGRES_DB=kithly_production_db

REDIS_URL=redis://redis-queue:6379/0

FASTAPI_ENV=production

